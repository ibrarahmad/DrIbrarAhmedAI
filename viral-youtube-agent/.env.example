# config — copy to .env and fill in. NEVER commit your real key.
#   cp .env.example .env
#
# Get a key: https://console.cloud.google.com → enable "YouTube Data API v3".
# Without a key the pipeline still runs end-to-end on the bundled sample data.

YOUTUBE_API_KEY=***************
TOPIC=AI tools
REGION=US
MAX_RESULTS=50
MIN_VIEWS=10000
DAYS_BACK=60

# Scoring model. "local-llm" uses Ollama at OLLAMA_URL; "heuristic" needs no model.
MODEL=local-llm
OLLAMA_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b
