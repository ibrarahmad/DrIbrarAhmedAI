# config — copy to .env and edit. No API key required; the agent runs locally.
#   cp .env.example .env

TOPIC=youtube hooks for creators
SCORE_THRESHOLD=80

# Scoring engine: "heuristic" (no model, default) or "local-llm" (Ollama).
MODEL=heuristic
OLLAMA_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5-coder:7b

# Your current hook — the agent scores it as a baseline to beat (optional).
MY_HOOK=How to Write Better YouTube Hooks
